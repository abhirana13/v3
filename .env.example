# --- Redshift (READ-ONLY) ---
# Use a user with SELECT-only grants. Never check real values into git.
REDSHIFT_HOST=your-cluster.xxxxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=readonly_user
REDSHIFT_PASSWORD=

# --- Metadata Postgres (local, run by docker compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics_dash
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_dev_password

# --- DuckDB aggregate cache ---
DUCKDB_PATH=/data/aggregates.duckdb

# --- Backend ---
LOG_LEVEL=INFO

# --- Production / AWS (not needed for local dev) ---

# Subdomain this tool is served on — no scheme, no trailing slash.
# e.g. analytics.internal.felicitytools.com
APP_DOMAIN=analytics.internal.felicitytools.com

# --- Google OAuth2 via oauth2-proxy ---
# Create an OAuth2 app at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://<APP_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret

# SHARED SECRET — must be identical across all tools on the same EC2.
# Enables single login across all *.internal.felicitytools.com subdomains.
# Generate once: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Then copy the same value into every tool's .env — do NOT regenerate per tool.
OAUTH2_PROXY_COOKIE_SECRET=replace-with-shared-32-byte-base64-value

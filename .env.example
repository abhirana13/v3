# --- Redshift (READ-ONLY) ---
# Use a user with SELECT-only grants. Never check real values into git.
REDSHIFT_HOST=your-cluster.xxxxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=readonly_user
REDSHIFT_PASSWORD=

# --- Metadata Postgres (local, run by docker compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics_dash
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_dev_password

# --- DuckDB aggregate cache ---
DUCKDB_PATH=/data/aggregates.duckdb

# --- Backend ---
LOG_LEVEL=INFO

# --- Production / AWS (not needed for local dev) ---

# --- Google OAuth2 via oauth2-proxy ---
# Redirect URI is hardcoded in docker-compose.prod.yml:
#   https://analytics.internal.felicitytools.com/oauth2/callback
# Add this URI to the existing OAuth2 client in Google Cloud Console.
OAUTH2_PROXY_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret

# SHARED SECRET — managed by the platform repo (felicity-internal-tools).
# Copy from /opt/tools/shared-cookie-secret.txt on the EC2.
# Do NOT generate a new value — using the same secret across all tools
# is what enables single login across *.internal.felicitytools.com.
# Must be exactly 16, 24, or 32 characters. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
OAUTH2_PROXY_COOKIE_SECRET=copy-from-platform-repo-shared-secret

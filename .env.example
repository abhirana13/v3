# --- Redshift (READ-ONLY) ---
# Use a user with SELECT-only grants. Never check real values into git.
REDSHIFT_HOST=your-cluster.xxxxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=readonly_user
REDSHIFT_PASSWORD=

# --- Metadata Postgres (local, run by docker compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics_dash
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_dev_password

# --- DuckDB aggregate cache ---
DUCKDB_PATH=/data/aggregates.duckdb

# --- Backend ---
LOG_LEVEL=INFO
